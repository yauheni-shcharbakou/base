{
  "name": "@packages/proto",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "format": "prettier src --write --config ../../.prettierrc",
    "dev": "pnpm build --watch",
    "build": "tsdown",
    "compile": "tsx compiler/main.ts && pnpm format --log-level error",
    "reset": "rm -rf .turbo dist node_modules",
    "reset:modules": "rm -rf node_modules"
  },
  "devDependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@packages/compiler-utils": "workspace:*",
    "@packages/configs": "workspace:*",
    "@types/pug": "2.0.10",
    "protobufjs": "7.5.8",
    "pug": "3.0.4",
    "ts-morph": "28.0.0",
    "ts-proto": "2.11.6",
    "tsx": "4.21.0"
  }
}
