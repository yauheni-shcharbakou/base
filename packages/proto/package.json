{
  "name": "@packages/proto",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "format": "prettier src --write --config ../../.prettierrc",
    "dev": "pnpm build --watch",
    "build": "tsdown src/index.ts --format cjs,esm --dts",
    "compile": "NODE_PATH=. ts-node-dev --project tsconfig.compiler.json --transpile-only compiler/main.ts && pnpm format",
    "reset": "rm -rf .turbo dist src node_modules",
    "reset:modules": "rm -rf node_modules"
  },
  "devDependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@packages/configs": "workspace:*",
    "@types/pug": "2.0.10",
    "protobufjs": "7.5.5",
    "pug": "3.0.4",
    "tsconfig-paths": "4.2.0",
    "ts-morph": "28.0.0",
    "ts-node-dev": "2.0.0",
    "ts-proto": "2.11.6"
  }
}
