{
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["src/**", "package.json", "ts-config*.json", "proto/**"],
      "outputs": ["dist/**"]
    },
    "compile": {
      "inputs": ["package.json", "ts-config*.json", "proto/**", "compiler/**"],
      "outputs": ["src/**"]
    },
    "format": {
      "inputs": ["src/**/*.ts"],
      "outputs": ["src/**/*.ts"]
    },
    "reset:modules": {
      "inputs": ["package.json"]
    }
  }
}
