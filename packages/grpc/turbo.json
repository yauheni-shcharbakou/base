{
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["src/**", "package.json", "ts-config*.json", "proto/**"],
      "outputs": ["dist/**"],
      "dependsOn": ["^compile", "^build", "compile", "format"]
    },
    "format": {
      "dependsOn": ["compile"]
    },
    "compile": {
      "inputs": ["package.json", "ts-config*.json", "proto/**", "compiler/**"],
      "outputs": ["src/**"]
    },
    "reset:modules": {
      "inputs": ["node_modules/**"]
    }
  }
}
