each service in data.services
    - const serviceId = pascalCase(service.id)
    - const client = `Grpc${serviceId}ServiceClient`

    |
    |export class Grpc#{serviceId}Repository {
    |   protected readonly client: #{client};
    |
    |   constructor(
    |       address: string,
    |       credentials: ChannelCredentials = ChannelCredentials.createInsecure(),
    |       options?: Partial<ClientOptions>
    |   ) {
    |       this.client = new #{client}(address, credentials, options);
    |   }
    |
    |   getClient(): #{client} {
    |       return this.client;
    |   }
    |
    each unaryMethod in service.unaryMethods
        |
        |   #{unaryMethod.name}(
        |       request: !{unaryMethod.requestType},
        |       metadata: Metadata = new Metadata(),
        |       options: Partial<CallOptions> = {},
        |   ): Promise<!{unaryMethod.responseType}> {
        |       return new Promise<!{unaryMethod.responseType}>((resolve, reject) => {
        |           this.client.#{unaryMethod.name}(request, metadata, options, (err, response) => {
        |               if (err) {
        |                   reject(err);
        |               } else {
        |                   resolve(response);
        |               }
        |           });
        |       });
        |   }
        |
    |}
    |
