{
  "name": "@backend/proto",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "format": "prettier src --write --config ../../../.prettierrc --log-level error",
    "dev": "pnpm build --watch",
    "build": "pnpm format && tsdown src/index.ts --format cjs --dts",
    "reset": "rm -rf .turbo dist src node_modules",
    "reset:modules": "rm -rf node_modules"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@nestjs/common": "11.1.19",
    "@nestjs/microservices": "11.1.19",
    "protobufjs": "7.5.5",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@packages/configs": "workspace:*",
    "@packages/proto": "workspace:*"
  }
}
