{
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["src/**/*.ts", "package.json", "ts-config*.json"],
      "outputs": ["dist/**"],
      "dependsOn": ["^compile", "^build", "compile", "format"]
    },
    "format": {
      "dependsOn": ["^compile", "^build", "compile"]
    },
    "compile": {
      "inputs": ["src/**/*.ts", "src/**/*.pug", "package.json", "ts-config*.json"],
      "outputs": ["src/nats_/compiler/generated/**"]
    },
    "reset:modules": {
      "inputs": ["node_modules/**"]
    }
  }
}
