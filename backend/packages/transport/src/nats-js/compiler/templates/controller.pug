- const service = pascalCase(data.service.id)
- const streamName = `${kebabCase(data.service.nameSpace)}-stream`

|
|export const NatsJs#{service}Service = {
|
each method in data.methods
    |       #{constantCase(method.name)}: {
    |           pattern: '!{method.event}',
    |           stream: {
    |               name: '!{streamName}',
    |               subjects: ['!{method.event}'],
    |           },
    |       },
    |
|   Controller: (): ClassDecorator => {
|       const methodsDecorator = function(constructor: Function) {
each method in data.methods
    |
    |           EventPattern('!{method.event}')(
    |               constructor.prototype['!{method.name}'],
    |               '!{method.name}',
    |               Reflect.getOwnPropertyDescriptor(constructor.prototype, '#{camelCase(method.name)}')
    |           );
    |
    |           globalStreamRegistry.append({ name: '!{kebabCase(data.service.nameSpace)}-stream', subjects: ['!{method.event}'] });
    |
|       };
|
|       return applyDecorators(Controller(), UseInterceptors(NatsJsControllerInterceptor), methodsDecorator);
|   },
|} as const;
|
|export interface NatsJs#{service}EventController {
|
each method in data.methods
    |   #{method.name}(event: !{method.type}, context?: NatsJetStreamContext): void | Promise<void> | Observable<void>;
    |
|}
|
