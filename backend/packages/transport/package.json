{
  "name": "@backend/transport",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "format": "prettier src --write --config ../../../.prettierrc",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "dev": "pnpm build --watch",
    "compile": "ts-node-dev --transpile-only src/nats_/compiler/main.ts",
    "build": "tsdown src/index.ts --format cjs --dts",
    "reset": "rm -rf .turbo dist node_modules src/nats_/compiler/generated",
    "reset:modules": "rm -rf node_modules"
  },
  "dependencies": {
    "@backend/common": "workspace:*",
    "@backend/grpc": "workspace:*",
    "@grpc/grpc-js": "1.14.3",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.3",
    "@nestjs/microservices": "11.1.19",
    "@nestjs-plugins/nestjs-nats-jetstream-transport": "2.2.6",
    "@packages/common": "workspace:*",
    "@sweet-monads/either": "3.3.1",
    "class-validator": "0.14.3",
    "long": "5.3.2",
    "mongoose": "9.0.2",
    "nats": "2.29.3",
    "protobufjs": "7.5.5",
    "pug": "3.0.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "ts-morph": "27.0.2"
  },
  "devDependencies": {
    "@packages/configs": "workspace:*",
    "@types/pug": "2.0.10",
    "tsconfig-paths": "4.2.0",
    "ts-node-dev": "2.0.0"
  }
}
