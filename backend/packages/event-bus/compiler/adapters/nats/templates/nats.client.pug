each service in data.services
    |
    |class Nats#{pascalCase(service.eventBusName)}ClientImpl implements #{service.eventBusName} {
    |   constructor(protected readonly client: NatsJetStreamClientProxy) {}
    |
    each method in service.methods
        - const eventPattern = kebabCase(method.eventId)
        |
        |   #{method.fullName}(data: #{method.type}): Observable<any> {
        |       return this.client.emit('#{eventPattern}', data);
        |   }
        |
    |}
    |
|
|export class NatsClientFactory {
|   private static clientsMap = new Map<Abstract<EventBus>, Type>([
|
each service in data.services
    |     [#{service.eventBusName}, Nats#{pascalCase(service.eventBusName)}ClientImpl],
    |
|   ]);
|
|   static create(client: NatsJetStreamClientProxy, EventBusClass: Abstract<EventBus>): Type {
|       const Client = this.clientsMap.get(EventBusClass);
|
|       if (!Client) {
|           throw new Error(`Nats client for ${EventBusClass} not found`);
|       }
|
|       return new Client(client);
|   }
|}
|
