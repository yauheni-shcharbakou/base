{
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["src/**/*.ts", "package.json", "tsconfig*.json", "tsdown.config.mts"],
      "outputs": ["dist/**"]
    },
    "compile": {
      "inputs": ["src/strategy/**/*.ts", "compiler/**", "package.json", "tsconfig*.json"],
      "outputs": ["src/generated/**"]
    }
  }
}
