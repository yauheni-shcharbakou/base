{
  "name": "@backend/grpc",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "format": "prettier src --write --config ../../../.prettierrc",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "dev": "pnpm build --watch",
    "build": "tsdown src/index.ts --format cjs --dts",
    "reset": "rm -rf .turbo dist node_modules",
    "reset:modules": "rm -rf node_modules"
  },
  "dependencies": {
    "@backend/common": "workspace:*",
    "@backend/proto": "workspace:*",
    "@grpc/grpc-js": "1.14.3",
    "@nestjs/common": "11.1.21",
    "@nestjs/config": "4.0.4",
    "@nestjs/microservices": "11.1.21",
    "@packages/common": "workspace:*",
    "@sweet-monads/either": "3.3.1",
    "protobufjs": "7.5.8",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@packages/configs": "workspace:*"
  }
}
