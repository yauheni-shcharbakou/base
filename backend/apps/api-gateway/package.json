{
  "name": "backend.api-gateway",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm start:dev",
    "prod": "pnpm start:prod",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" --config ../../../.prettierrc",
    "start": "nest start",
    "start:dev": "dotenv -- nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "reset": "rm -rf .turbo dist node_modules",
    "reset:modules": "rm -rf node_modules"
  },
  "dependencies": {
    "@backend/common": "workspace:*",
    "@backend/persistence": "workspace:*",
    "@backend/transport": "workspace:*",
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.19",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.3.0",
    "@nestjs/throttler": "6.5.0",
    "@packages/common": "workspace:*",
    "@sweet-monads/either": "3.3.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.19",
    "@packages/configs": "workspace:*",
    "@types/express": "5.0.5",
    "@types/jest": "30.0.0",
    "@types/supertest": "6.0.3",
    "jest": "30.3.0",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
