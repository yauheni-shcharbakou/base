{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "10",
  "envMode": "loose",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^compile", "^build", "compile"]
    },
    "compile": {
      "dependsOn": ["^compile", "^build"]
    },
    "prod": {},
    "format": {},
    "lint": {},
    "reset": {},
    "reset:modules": {}
  }
}
