{
  "name": "base",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "scripts": {
    "compile": "turbo run compile",
    "compile:grpc": "turbo run compile --filter=@packages/grpc",
    "compile:transport": "turbo run compile --filter=@backend/transport",
    "dev": "turbo run dev --filter=\"backend.*\" --filter=\"frontend.*\"",
    "dev:backend": "turbo run dev --filter=\"backend.*\"",
    "dev:backend.api-gateway": "turbo run dev --filter=backend.api-gateway",
    "dev:backend.auth": "turbo run dev --filter=backend.auth",
    "dev:backend.storage": "turbo run dev --filter=backend.storage",
    "dev:frontend": "turbo run dev --filter=\"frontend.*\"",
    "dev:frontend.admin": "turbo run dev --filter=frontend.admin",
    "build": "turbo run build",
    "build:backend": "turbo run build --filter=\"backend.*\"",
    "build:backend.api-gateway": "turbo run build --filter=backend.api-gateway",
    "build:backend.auth": "turbo run build --filter=backend.auth",
    "build:backend.storage": "turbo run build --filter=backend.storage",
    "build:frontend": "turbo run build --filter=\"frontend.*\"",
    "build:frontend.admin": "turbo run build --filter=frontend.admin",
    "build:grpc": "turbo run build --filter=\"@*/grpc\"",
    "prod": "turbo run prod",
    "prod:backend": "turbo run prod --filter=\"backend.*\"",
    "prod:backend.api-gateway": "turbo run prod --filter=backend.api-gateway",
    "prod:backend.auth": "turbo run prod --filter=backend.auth",
    "prod:backend.storage": "turbo run prod --filter=backend.storage",
    "prod:frontend": "turbo run prod --filter=\"frontend.*\"",
    "prod:frontend.admin": "turbo run prod --filter=frontend.admin",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "gen:package": "turbo gen package && yarn",
    "reset": "turbo run reset && rm -rf .turbo node_modules pnpm-lock.yaml",
    "reset:backend": "turbo run reset --filter=\"backend.*\"",
    "reset:frontend": "turbo run reset --filter=\"frontend.*\"",
    "reset:modules": "turbo run reset:modules && rm -rf node_modules",
    "docker:local": "docker compose -f docker-compose.yml --profile local up --build",
    "docker": "docker compose -f docker-compose.yml --profile all up --build"
  },
  "dependencies": {
    "lodash": "4.18.1",
    "moment": "2.30.1",
    "ulid": "3.0.2",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@turbo/gen": "2.9.6",
    "@types/lodash": "4.17.23",
    "@types/node": "22.19.3",
    "change-case-all": "2.1.0",
    "dotenv-cli": "11.0.0",
    "minimatch": "10.2.4",
    "pnpm": "10.33.0",
    "prettier": "3.7.4",
    "tsdown": "0.21.9",
    "turbo": "2.9.6",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.15.1",
      "lodash": "4.18.1",
      "protobufjs": "7.5.5",
      "react-hook-form": "7.57.0"
    },
    "ignoredBuiltDependencies": [
      "@scarf/scarf"
    ],
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
