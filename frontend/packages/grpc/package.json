{
  "name": "@frontend/grpc",
  "private": true,
  "author": "Yauheni Shcharbakou <iipekolict@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "format": "prettier src --write --config ../../../.prettierrc",
    "dev": "pnpm build --watch",
    "build": "tsdown src/index.ts --format cjs,esm --dts --no-treeshake",
    "reset": "rm -rf .turbo dist src node_modules",
    "reset:modules": "rm -rf node_modules"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@grpc/grpc-js": "1.14.3",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@packages/configs": "workspace:*",
    "@packages/grpc": "workspace:*"
  }
}
